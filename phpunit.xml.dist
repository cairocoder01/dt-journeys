<?xml version="1.0"?>
<phpunit
	bootstrap="test/bootstrap.php"
	backupGlobals="false"
	colors="true"
	convertErrorsToExceptions="true"
	convertNoticesToExceptions="true"
	convertWarningsToExceptions="true"
	>
	<testsuites>
		<testsuite name="all">
			<directory suffix="Test.php">./test/</directory>
			<exclude>./test/CleanupTest.php</exclude>
			<file>./test/CleanupTest.php</file>
		</testsuite>
	</testsuites>
</phpunit>
